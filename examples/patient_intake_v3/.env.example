# patient_intake v1.0.0 — environment variables
# Copy this file to .env and fill in your values.
# OpenAI API key (required)
OPENAI_API_KEY=sk-...

# Optional: override the default LLM model
# LLM_MODEL=gpt-4o

# Audit logging
# Set to 1 to write audit logs to a file instead of stdout
AUDIT_LOG_TO_FILE=0
# AUDIT_LOG_PATH=/var/log/patient_intake/audit.jsonl
