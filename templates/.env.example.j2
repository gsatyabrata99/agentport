# {{ schema.name }} v{{ schema.version }} — environment variables
# Copy this file to .env and fill in your values.
{% if schema.llm.provider == "anthropic" %}
# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...
{% elif schema.llm.provider == "openai" %}
# OpenAI API key (required)
OPENAI_API_KEY=sk-...
{% endif %}

# Optional: override the default LLM model
# LLM_MODEL={{ schema.llm.model }}

# Audit logging
# Set to 1 to write audit logs to a file instead of stdout
AUDIT_LOG_TO_FILE=0
# AUDIT_LOG_PATH=/var/log/{{ schema.name }}/audit.jsonl
