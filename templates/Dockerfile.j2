FROM python:3.13-slim

LABEL org.opencontainers.image.title="{{ schema.name }}"
LABEL org.opencontainers.image.version="{{ schema.version }}"
LABEL org.opencontainers.image.description="{{ schema.description }}"

# Non-root user for security
RUN useradd --create-home --shell /bin/bash agent
WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .
RUN chown -R agent:agent /app
USER agent

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/health')"

CMD ["uvicorn", "{{ schema.name }}.main:app", "--host", "0.0.0.0", "--port", "8080"]
