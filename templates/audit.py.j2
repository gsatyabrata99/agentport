from __future__ import annotations

import json
import logging
import os
from datetime import datetime, timezone
from typing import Any

_logger = logging.getLogger("agentport.audit.{{ schema.name }}")

# Prevent duplicate handlers if module is reloaded in tests
if not _logger.handlers:
    _use_file = os.getenv("AUDIT_LOG_TO_FILE", "").lower() in ("1", "true", "yes")
    _log_path = os.getenv("AUDIT_LOG_PATH", "/var/log/{{ schema.name }}/audit.jsonl")
    if _use_file:
        os.makedirs(os.path.dirname(_log_path), exist_ok=True)
        _handler: logging.Handler = logging.FileHandler(_log_path)
    else:
        _handler = logging.StreamHandler()
    _handler.setFormatter(logging.Formatter("%(message)s"))
    _logger.addHandler(_handler)
    _logger.setLevel(logging.INFO)
    _logger.propagate = False


def log_event(
    event_type: str,
    agent: str,
    details: dict[str, Any],
    user_id: str | None = None,
) -> None:
    """Emit a single structured audit event."""
    entry: dict[str, Any] = {
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "event_type": event_type,
        "agent": agent,
        "user_id": user_id,
        "details": details,
    }
    _logger.info(json.dumps(entry, default=str))
